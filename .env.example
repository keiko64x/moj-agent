# Skopiuj jako .env.local na serwerze i uzupełnij wartości.

# Klucz Google Gemini / Generative AI (wymagany do czatu / ReAct / travel)
GOOGLE_GENERATIVE_AI_API_KEY=wstaw_tutaj_swoj_klucz

# Opcjonalnie kolejne klucze (failover limitów)
# GOOGLE_GENERATIVE_AI_API_KEY_2=
# GOOGLE_GENERATIVE_AI_API_KEY_3=

# Generowanie obrazów — fallback przy limicie API (true/false)
IMAGE_FALLBACK_ENABLED=true

# Search Grounding / google_search — PŁATNE ($14/1000). Domyślnie WYŁĄCZONE.
# Odblokuj TYLKO do testów, potem USUŃ tę linię:
# ENABLE_SEARCH_GROUNDING=true

# --- Lekcja 5 / Warsztat 1: Supabase ---
# Settings → API w dashboardzie Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...twoj_anon_key
